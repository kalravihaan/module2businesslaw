function getBotReply(input) {
  const q = input.toLowerCase();
  if (q.includes('minor')) return 'Minor agreement is void ab initio. Minor can be beneficiary, can be agent, and is liable only for necessaries supplied from property, not personally.';
  if (q.includes('offer') && q.includes('invitation')) return 'Offer is capable of immediate acceptance. Invitation to offer merely invites others to make offers. Example: menu card, display of goods, price catalogue.';
  if (q.includes('consideration')) return 'Consideration is something in return under Section 2(d). It must move at promisor’s desire and may move from promisee or any other person.';
  if (q.includes('fraud') || q.includes('misrepresentation')) return 'Fraud involves intent to deceive; misrepresentation is false statement made innocently. Both affect free consent, but fraud is more serious.';
  if (q.includes('quasi')) return 'Quasi contracts are not real contracts. Law imposes them to prevent unjust enrichment. Key areas: necessaries, non-gratuitous acts, finder of goods, mistake/coercion.';
  if (q.includes('void')) return 'Void agreement has no legal effect. Common examples: unlawful object, no consideration (subject to exceptions), restraint of trade, wagering, impossible acts.';
  return 'Use the Slide Explorer or search a keyword. For exam answers, write: Definition/Rule → Section/Case → Application → Conclusion.';
}

