        <motion.div initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} className="grid md:grid-cols-4 gap-4">
          <Card className="md:col-span-3 rounded-3xl shadow-sm border-0 bg-white">
            <CardContent className="p-6 md:p-8">
              <div className="flex items-start justify-between gap-4">
                <div>
                  <h1 className="text-3xl md:text-5xl font-bold tracking-tight">Business Law Final Exam App</h1>
                  <p className="text-slate-600 mt-2 text-base md:text-lg">Module 1 — The Indian Contract Act, 1872</p>
                  <p className="text-sm text-slate-500 mt-2">Final version upgraded for complete slide-by-slide learning, active recall, exam drilling, and chatbot-style revision.</p>
                </div>
                <Badge className="rounded-full px-4 py-2 text-sm"><GraduationCap className="w-4 h-4 mr-1" /> Final Exam Build</Badge>
              </div>
            </CardContent>
          </Card>
          <Card className="rounded-3xl shadow-sm border-0 bg-white">
            <CardContent className="p-6 space-y-3">
              <div className="text-sm text-slate-500">Slide Coverage</div>
              <div className="text-4xl font-bold">{coverage}%</div>
              <div className="text-sm text-slate-600">All 92 slides mapped into the app, including transition/blank-style slides.</div>
              <Progress value={coverage} className="h-3" />
            </CardContent>
          </Card>
        </motion.div>

        <Tabs value={tab} onValueChange={setTab} className="space-y-4">
          <TabsList className="grid grid-cols-3 md:grid-cols-6 rounded-2xl h-auto p-1 bg-white shadow-sm">
            <TabsTrigger value="slides" className="rounded-xl py-3"><BookOpen className="w-4 h-4 mr-2" />Slides</TabsTrigger>
            <TabsTrigger value="quiz" className="rounded-xl py-3"><Brain className="w-4 h-4 mr-2" />Quiz</TabsTrigger>
            <TabsTrigger value="flashcards" className="rounded-xl py-3"><RotateCcw className="w-4 h-4 mr-2" />Flashcards</TabsTrigger>
            <TabsTrigger value="exam" className="rounded-xl py-3"><Trophy className="w-4 h-4 mr-2" />Exam</TabsTrigger>
            <TabsTrigger value="coach" className="rounded-xl py-3"><Bot className="w-4 h-4 mr-2" />Coach</TabsTrigger>
            <TabsTrigger value="cases" className="rounded-xl py-3"><Gavel className="w-4 h-4 mr-2" />Cases</TabsTrigger>
          </TabsList>

          <TabsContent value="slides">
            <div className="grid lg:grid-cols-[340px_1fr] gap-6">
              <Card className="rounded-3xl shadow-sm border-0 bg-white h-fit">
                <CardHeader>
                  <CardTitle className="text-xl">Slide Explorer</CardTitle>
                  <div className="space-y-3">
                    <div className="relative">
                      <Search className="w-4 h-4 absolute left-3 top-3 text-slate-400" />
                      <Input value={search} onChange={(e) => setSearch(e.target.value)} placeholder="Search any concept..." className="pl-9 rounded-xl" />
                    </div>
                    <div className="flex flex-wrap gap-2">
                      <Button size="sm" variant={selectedModule === 'All' ? 'default' : 'outline'} className="rounded-full" onClick={() => setSelectedModule('All')}>All</Button>
                      {moduleNames.map((m) => (
                        <Button key={m} size="sm" variant={selectedModule === m ? 'default' : 'outline'} className="rounded-full" onClick={() => setSelectedModule(m)}>{m}</Button>
                      ))}
                    </div>
                  </div>
                </CardHeader>
                <CardContent className="space-y-2 max-h-[72vh] overflow-auto">
                  {filteredSlides.map((s) => (
                    <button key={s.slide} onClick={() => setSelectedSlide(s.slide)} className={`w-full text-left p-3 rounded-2xl transition ${current.slide === s.slide ? 'bg-slate-900 text-white' : 'bg-slate-100 hover:bg-slate-200 text-slate-800'}`}>
                      <div className="text-xs opacity-80">Slide {s.slide}</div>
                      <div className="font-semibold text-sm">{s.title}</div>
                      <div className={`text-xs mt-1 ${current.slide === s.slide ? 'text-slate-300' : 'text-slate-500'}`}>{s.summary}</div>
                    </button>
                  ))}
                </CardContent>
              </Card>

              <AnimatePresence mode="wait">
                <motion.div key={current.slide} initial={{ opacity: 0, y: 12 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, y: -12 }}>
                  <Card className="rounded-3xl shadow-sm border-0 bg-white">
                    <CardHeader>
                      <div className="flex items-center justify-between gap-4">
                        <div>
                          <div className="text-sm text-slate-500 mb-1">Slide {current.slide} • {current.module}</div>
                          <CardTitle className="text-2xl md:text-3xl">{current.title}</CardTitle>
                          <p className="text-slate-600 mt-2">{current.summary}</p>
                        </div>
                        <Badge className="rounded-full">100% Mapped</Badge>
                      </div>
                    </CardHeader>
                    <CardContent className="space-y-6">
                      <div>
                        <h3 className="font-semibold text-lg mb-3">Teach Me This Slide</h3>
                        <ul className="space-y-3">
                          {current.learn.map((point, i) => (
                            <li key={i} className="flex gap-3 p-4 rounded-2xl bg-slate-50">
                              <div className="w-7 h-7 rounded-full bg-slate-900 text-white flex items-center justify-center text-sm shrink-0">{i + 1}</div>
                              <div className="leading-7 text-slate-800">{point}</div>
                            </li>
                          ))}
                        </ul>
                      </div>

                      <div className="p-4 rounded-2xl bg-amber-50 border border-amber-200">
                        <div className="font-semibold mb-1">Exam Hook</div>
                        <div>{current.examHook}</div>
                      </div>

                      {current.quickCheck.length > 0 && (
                        <div>
                          <h3 className="font-semibold text-lg mb-3">Quick Check</h3>
                          <Accordion type="single" collapsible>
                            {current.quickCheck.map((qc, i) => (
                              <AccordionItem key={i} value={`qc-${i}`}>
                                <AccordionTrigger>{qc.q}</AccordionTrigger>
                                <AccordionContent>{qc.a}</AccordionContent>
                              </AccordionItem>
                            ))}
                          </Accordion>
                        </div>
                      )}

                      <div className="flex gap-3">
                        <Button className="rounded-xl" onClick={() => setSelectedSlide(Math.max(1, current.slide - 1))}>Previous</Button>
                        <Button className="rounded-xl" onClick={() => setSelectedSlide(Math.min(92, current.slide + 1))}>Next</Button>
                      </div>
                    </CardContent>
                  </Card>
                </motion.div>
              </AnimatePresence>
            </div>
          </TabsContent>

          <TabsContent value="quiz">
            <Card className="rounded-3xl shadow-sm border-0 bg-white max-w-3xl mx-auto">
              <CardHeader>
                <div className="flex items-center justify-between gap-4">
                  <div>
                    <CardTitle className="text-2xl">Rapid Recall Quiz</CardTitle>
                    <p className="text-slate-600 mt-1">You either know it or you don’t. Good.</p>
                  </div>
                  <Badge className="rounded-full px-3 py-1">Score: {score}/{quiz.length}</Badge>
                </div>
                <Progress value={((quizIndex + (showExplain ? 1 : 0)) / quiz.length) * 100} className="h-3" />
              </CardHeader>
              <CardContent className="space-y-6">
                <div className="text-sm text-slate-500">Question {quizIndex + 1} of {quiz.length}</div>
                <div className="text-xl font-semibold">{quiz[quizIndex].q}</div>
                <div className="grid gap-3">
                  {quiz[quizIndex].options.map((option) => {
                    const isCorrect = option === quiz[quizIndex].answer;
                    const isPicked = picked === option;
                    return (
                      <button key={option} onClick={() => answerQuestion(option)} className={`text-left p-4 rounded-2xl border transition ${picked ? isCorrect ? 'bg-green-50 border-green-300' : isPicked ? 'bg-red-50 border-red-300' : 'bg-slate-50' : 'hover:bg-slate-50'}`}>
                        <div className="flex items-center justify-between">
                          <span>{option}</span>
                          {picked && isCorrect && <CheckCircle2 className="w-5 h-5 text-green-600" />}
                          {picked && isPicked && !isCorrect && <XCircle className="w-5 h-5 text-red-600" />}
                        </div>
                      </button>
                    );
                  })}
                </div>
                {showExplain && <div className="p-4 rounded-2xl bg-slate-100"><div className="font-semibold mb-1">Explanation</div><div>{quiz[quizIndex].explain}</div></div>}
                <div className="flex gap-3">
                  {quizIndex < quiz.length - 1 ? <Button onClick={nextQuestion} disabled={!showExplain} className="rounded-xl">Next</Button> : <Button onClick={restartQuiz} className="rounded-xl">Restart Quiz</Button>}
                </div>
              </CardContent>
            </Card>
          </TabsContent>

          <TabsContent value="flashcards">
            <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
              {flashcards.map((card, i) => {
                const isOpen = flipped[i];
                return (
                  <motion.div key={i} whileHover={{ y: -3 }}>
                    <Card onClick={() => setFlipped((s) => ({ ...s, [i]: !s[i] }))} className="cursor-pointer rounded-3xl shadow-sm border-0 bg-white min-h-[220px] flex items-center justify-center p-6">
                      <CardContent className="text-center p-0">
                        <div className="text-sm text-slate-500 mb-3">Tap to flip</div>
                        <div className="font-semibold text-lg leading-8">{isOpen ? card.back : card.front}</div>
                      </CardContent>
                    </Card>
                  </motion.div>
                );
              })}
            </div>
          </TabsContent>

          <TabsContent value="exam">
            <div className="grid lg:grid-cols-2 gap-6">
              <Card className="rounded-3xl shadow-sm border-0 bg-white">
                <CardHeader><CardTitle className="flex items-center gap-2"><Timer className="w-5 h-5" /> Exam Sprint</CardTitle></CardHeader>
                <CardContent className="space-y-4">
                  <div className="text-5xl font-bold">{examTimer} min</div>
                  <p className="text-slate-600">Recommended plan tonight:</p>
                  <ul className="list-disc pl-5 space-y-2 text-slate-700">
                    <li>20 min — Offer, Acceptance, Consideration</li>
                    <li>15 min — Capacity + Free Consent</li>
                    <li>10 min — Void Agreements + Quasi Contracts</li>
                    <li>10 min — Discharge + Remedies</li>
                    <li>5 min — Case activities</li>
                  </ul>
                  <Button className="rounded-xl" onClick={() => setExamTimer(45)}>Switch to 45-min panic mode</Button>
                </CardContent>
              </Card>

              <Card className="rounded-3xl shadow-sm border-0 bg-white">
                <CardHeader><CardTitle>Predicted Exam Questions</CardTitle></CardHeader>
                <CardContent className="space-y-3">
                  {[
                    'Define contract. Distinguish agreement and contract.',
                    'Explain essentials of a valid contract under Section 10.',
                    'Discuss legal rules regarding offer and acceptance with cases.',
                    'Explain doctrine of privity of contract and its exceptions.',
                    'What is consideration? State its legal rules and exceptions to “no consideration, no contract”.',
                    'Explain minor’s agreements under Indian law.',
                    'Discuss free consent and distinguish coercion, fraud and misrepresentation.',
                    'Explain void agreements under the Indian Contract Act.',
                    'What are quasi contracts? Explain their kinds.',
                    'Explain discharge of contract and remedies for breach.'
                  ].map((q, i) => <div key={i} className="p-3 rounded-2xl bg-slate-50">{q}</div>)}
                </CardContent>
              </Card>
            </div>
          </TabsContent>

          <TabsContent value="coach">
            <Card className="rounded-3xl shadow-sm border-0 bg-white max-w-4xl mx-auto">
              <CardHeader><CardTitle className="flex items-center gap-2"><Bot className="w-5 h-5" /> Module 1 Coach</CardTitle></CardHeader>
              <CardContent className="space-y-4">
                <div className="h-[420px] overflow-auto rounded-2xl bg-slate-50 p-4 space-y-3">
                  {chat.map((m, i) => (
                    <div key={i} className={`max-w-[85%] p-3 rounded-2xl ${m.role === 'user' ? 'ml-auto bg-slate-900 text-white' : 'bg-white border'}`}>{m.text}</div>
                  ))}
                </div>
                <div className="flex gap-3">
                  <Textarea value={chatInput} onChange={(e) => setChatInput(e.target.value)} placeholder="Ask: difference between fraud and misrepresentation, explain minor, what is quasi contract..." className="rounded-2xl" />
                  <Button onClick={sendChat} className="rounded-2xl h-auto px-6">Send</Button>
                </div>
              </CardContent>
            </Card>
          </TabsContent>

          <TabsContent value="cases">
            <div className="grid lg:grid-cols-2 gap-6">
              <Card className="rounded-3xl shadow-sm border-0 bg-white">
                <CardHeader><CardTitle>Must-Remember Cases</CardTitle></CardHeader>
                <CardContent className="space-y-3 text-slate-700">
                  {[
                    'Balfour v Balfour — legal intention',
                    'Carlill v Carbolic Smoke Ball Co. — general offer',
                    'Fitch v Snedaker — acceptance in ignorance invalid',
                    'Harvey v Facey — statement of price is not offer',
                    'Brogden v Metropolitan Rail Co. — communication of acceptance',
                    'Chinnaya v Ramayya — consideration may move from third party',
                    'Mohiri Bibi v Dharmodas Ghose — minor agreement void',
                    'Hadley v Baxendale — damages',
                    'Taylor v Caldwell — frustration/destruction of subject matter',
                    'Krell v Henry — non-occurrence of state of things'
                  ].map((c, i) => <div key={i} className="p-3 rounded-2xl bg-slate-50">{c}</div>)}
                </CardContent>
              </Card>
              <Card className="rounded-3xl shadow-sm border-0 bg-white">
                <CardHeader><CardTitle>How to Write Answers</CardTitle></CardHeader>
                <CardContent className="space-y-4 text-slate-700 leading-7">
                  <div className="p-4 rounded-2xl bg-slate-50">
                    <b>Use IRAC:</b><br />
                    <b>I</b>ssue → What is the legal problem?<br />
                    <b>R</b>ule → Write section/definition/case.<br />
                    <b>A</b>pplication → Apply facts.<br />
                    <b>C</b>onclusion → Clear answer.
                  </div>
                  <div className="p-4 rounded-2xl bg-slate-50">
                    <b>Best exam structure:</b><br />
                    Definition → Provision/Section → Explanation → Case law → Example → Conclusion
                  </div>
                </CardContent>
              </Card>
            </div>
          </TabsContent>
        </Tabs>
      </div>
    </div>
  );
}
